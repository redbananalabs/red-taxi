@inherits LayoutComponentBase
@inject DispatchState State
@inject IJSRuntime JS
@implements IDisposable

<div class="dispatch-shell">
    <!-- Sidebar -->
    <Sidebar />

    <!-- Main content area -->
    <div class="dispatch-main">
        <!-- Top bar -->
        <TopBar OnViewModeChanged="HandleViewModeChanged" />

        <!-- Content area -->
        <div class="dispatch-content @GetViewModeClass()">
            @Body
        </div>
    </div>
</div>

<!-- Command Palette overlay -->
@if (State.IsCommandPaletteOpen)
{
    <CommandPalette />
}

@code {
    private DotNetObjectReference<DispatchLayout>? _objRef;
    private TopBar.ViewMode _viewMode = TopBar.ViewMode.Map;

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("dispatchInterop.initKeyboard", _objRef);
        }
    }

    [JSInvokable]
    public void OnCommandPaletteToggle()
    {
        State.ToggleCommandPalette();
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnNewBooking()
    {
        State.OpenBookingForm();
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnEscapePressed()
    {
        if (State.IsCommandPaletteOpen)
            State.CloseCommandPalette();
        else if (State.IsDriverSelectorOpen)
            State.CloseDriverSelector();
        else if (State.IsBookingFormOpen)
            State.CloseBookingForm();
        else if (State.IsBookingDetailOpen)
            State.CloseBookingDetail();
        else if (State.IsDriverDetailOpen)
            State.CloseDriverDetail();

        InvokeAsync(StateHasChanged);
    }

    // DC23: Ctrl+S shortcut
    [JSInvokable]
    public void OnSaveBooking()
    {
        // Trigger form submit via state; BookingForm listens for this
        InvokeAsync(StateHasChanged);
    }

    // DC23: Ctrl+Enter shortcut
    [JSInvokable]
    public void OnConfirmBooking()
    {
        // Same as save
        InvokeAsync(StateHasChanged);
    }

    // DC30: View mode handling
    private void HandleViewModeChanged(TopBar.ViewMode mode)
    {
        _viewMode = mode;
        StateHasChanged();
    }

    private string GetViewModeClass() => _viewMode switch
    {
        TopBar.ViewMode.Map => "view-mode-map",
        TopBar.ViewMode.Diary => "view-mode-diary",
        TopBar.ViewMode.Split => "view-mode-split",
        _ => "view-mode-map"
    };

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
        _objRef?.Dispose();
    }
}

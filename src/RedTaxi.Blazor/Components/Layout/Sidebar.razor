@inject NavigationManager Nav

<nav class="sidebar">
    <div class="sidebar-logo">
        <span class="logo-text">RT</span>
    </div>

    <div class="sidebar-nav">
        <a href="/" class="sidebar-item @(IsActive("/") ? "active" : "")" title="Dashboard">
            <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" />
            </svg>
            <span class="sidebar-label">Dashboard</span>
        </a>

        <a href="/bookings" class="sidebar-item @(IsActive("/bookings") ? "active" : "")" title="Bookings">
            <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
                <rect x="9" y="3" width="6" height="4" rx="1" />
                <path d="M9 12h6" /><path d="M9 16h6" />
            </svg>
            <span class="sidebar-label">Bookings</span>
        </a>

        <a href="/accounts" class="sidebar-item @(IsActive("/accounts") ? "active" : "")" title="Accounts">
            <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            <span class="sidebar-label">Accounts</span>
        </a>

        <a href="/drivers" class="sidebar-item @(IsActive("/drivers") ? "active" : "")" title="Drivers">
            <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 17h2l.64-2.54a6 6 0 0 0-1.16-5.27L18 6h-2l-3 1H7L4 6H2L.52 9.19a6 6 0 0 0-1.16 5.27L0 17h2" />
                <circle cx="7" cy="17" r="2" /><circle cx="17" cy="17" r="2" />
            </svg>
            <span class="sidebar-label">Drivers</span>
        </a>

        <a href="/billing" class="sidebar-item @(IsActive("/billing") ? "active" : "")" title="Billing">
            <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>
            <span class="sidebar-label">Billing</span>
        </a>

        <a href="/reports" class="sidebar-item @(IsActive("/reports") ? "active" : "")" title="Reports">
            <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" />
            </svg>
            <span class="sidebar-label">Reports</span>
        </a>
    </div>

    <div class="sidebar-footer">
        <a href="/settings" class="sidebar-item @(IsActive("/settings") ? "active" : "")" title="Settings">
            <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3" />
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
            </svg>
            <span class="sidebar-label">Settings</span>
        </a>
    </div>
</nav>

@code {
    private bool IsActive(string href)
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        if (href == "/") return string.IsNullOrEmpty(relativePath);
        return relativePath.StartsWith(href.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }
}

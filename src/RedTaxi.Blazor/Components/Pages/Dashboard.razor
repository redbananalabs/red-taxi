@page "/"
@inject DispatchState State
@inject ApiService Api
@inject SignalRService SignalR
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Dispatch Console - Red Taxi</PageTitle>

<div class="dispatch-view-v2">
    <!-- KPI strip at top -->
    <div class="kpi-strip">
        <div class="kpi-item">
            <span class="kpi-value font-mono">@_kpis.TodayBookings</span>
            <span class="kpi-label">Today</span>
        </div>
        <div class="kpi-item kpi-warning">
            <span class="kpi-value font-mono">@_kpis.UnallocatedBookings</span>
            <span class="kpi-label">Unallocated</span>
        </div>
        <div class="kpi-item kpi-success">
            <span class="kpi-value font-mono">@_kpis.DriversOnline</span>
            <span class="kpi-label">Online</span>
        </div>
        <div class="kpi-item">
            <span class="kpi-value font-mono">@_kpis.ActiveJobs</span>
            <span class="kpi-label">Active</span>
        </div>
        <div class="kpi-item kpi-info">
            <span class="kpi-value font-mono">@_kpis.CompletedToday</span>
            <span class="kpi-label">Completed</span>
        </div>
        <div class="kpi-item">
            <span class="kpi-value font-mono">£@_kpis.TodayRevenue.ToString("N0")</span>
            <span class="kpi-label">Revenue</span>
        </div>
    </div>

    <!-- Split panel: left = booking form, right = tabbed (scheduler/map) -->
    <div class="split-panel">
        <!-- LEFT: Booking form (always visible) -->
        <div class="split-left" style="width: @(_leftWidthPercent)%; min-width: 320px;">
            <div class="form-panel-scroll">
                <BookingForm OnClose="@(() => {})"
                             OnBookingCreated="HandleBookingCreated" />
            </div>
        </div>

        <!-- Draggable splitter handle -->
        <div class="splitter-handle" @onmousedown="StartResize">
            <div class="splitter-grip"></div>
        </div>

        <!-- RIGHT: Tabbed (Scheduler / Map) -->
        <div class="split-right" style="flex: 1;">
            <!-- Tab bar -->
            <div class="tab-bar">
                <button class="tab-btn @(_activeTab == "scheduler" ? "tab-active" : "")"
                        @onclick='() => _activeTab = "scheduler"'>
                    <span>📋</span> Scheduler
                </button>
                <button class="tab-btn @(_activeTab == "map" ? "tab-active" : "")"
                        @onclick='() => _activeTab = "map"'>
                    <span>📍</span> Map
                </button>
            </div>

            <!-- Tab content -->
            <div class="tab-content">
                @if (_activeTab == "scheduler")
                {
                    <Timeline />
                }
                else
                {
                    <div class="map-tab-wrapper">
                        <MapView />
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Driver selector modal -->
    @if (State.IsDriverSelectorOpen && State.SelectedBooking != null)
    {
        <DriverSelector BookingId="State.SelectedBooking.Id"
                        OnClose="() => State.CloseDriverSelector()"
                        OnDriverSelected="HandleDriverAllocated" />
    }
</div>

@code {
    private DashboardKpiDto _kpis = new(0, 0, 0, 0m, 0, 0);
    private List<BookingDto> _bookings = new();
    private string _activeTab = "scheduler"; // default to scheduler per §142
    private int _leftWidthPercent = 35;

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
        SignalR.OnStateUpdated += HandleSignalRUpdate;
        SignalR.OnConnectionChanged += StateHasChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _ = SignalR.StartAsync(); // fire-and-forget, don't crash circuit
        }
        catch { }
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            var kpiTask = Api.GetDashboardKpisAsync();
            var bookingsTask = Api.GetBookingsAsync(DateTime.Today);
            await Task.WhenAll(kpiTask, bookingsTask);

            _kpis = await kpiTask ?? _kpis;
            _bookings = await bookingsTask ?? _bookings;
        }
        catch
        {
            // API not available - use defaults
        }
    }

    private async Task HandleBookingCreated(BookingDto booking)
    {
        State.SelectBooking(booking);
        await LoadData();
    }

    private void HandleAllocateRequest()
    {
        State.OpenDriverSelector();
    }

    private async Task HandleDriverAllocated(int driverUserId)
    {
        if (State.SelectedBooking != null)
        {
            try
            {
                await Api.AllocateDriverAsync(State.SelectedBooking.Id, driverUserId);
                State.CloseDriverSelector();
                await LoadData();
            }
            catch { }
        }
    }

    private async void HandleSignalRUpdate()
    {
        await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
    }

    // Splitter drag
    private void StartResize(MouseEventArgs e)
    {
        // JS interop would handle actual drag — for now, toggle between presets
        _leftWidthPercent = _leftWidthPercent == 35 ? 25 : _leftWidthPercent == 25 ? 45 : 35;
    }

    public ValueTask DisposeAsync()
    {
        State.OnChange -= StateHasChanged;
        SignalR.OnStateUpdated -= HandleSignalRUpdate;
        SignalR.OnConnectionChanged -= StateHasChanged;
        return ValueTask.CompletedTask;
    }
}

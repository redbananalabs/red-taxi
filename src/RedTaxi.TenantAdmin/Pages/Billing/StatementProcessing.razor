@page "/admin/billing/statements"
@attribute [Authorize]
@inject AdminApiClient Api

<PageTitle>Statement Processing - Red Taxi Admin</PageTitle>

<div class="page-header">
    <h1>Statement Processing</h1>
    <p class="text-secondary">Review uninvoiced driver jobs and create statements.</p>
</div>

<FormCard Title="Filters">
    <div class="form-row">
        <div class="form-group">
            <label>Driver</label>
            <select class="form-input" @bind="_selectedDriverId">
                <option value="0">-- All Drivers --</option>
                @foreach (var d in _drivers)
                {
                    <option value="@d.UserId">@d.FullName</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Scope</label>
            <select class="form-input" @bind="_selectedScope">
                <option value="-1">-- All Scopes --</option>
                <option value="0">Cash</option>
                <option value="1">Account</option>
                <option value="2">Card</option>
            </select>
        </div>
        <div class="form-group" style="align-self:flex-end;">
            <button class="btn btn-primary" @onclick="ApplyFilters">Apply</button>
        </div>
    </div>
</FormCard>

<div class="toolbar">
    <button class="btn btn-primary" @onclick="CreateStatement" disabled="@(!_selectedJobs.Any() || _processing)">
        @if (_processing) { <span class="spinner-sm"></span> } else { <span>Create Statement</span> }
    </button>
    <span class="text-secondary">@_selectedJobs.Count job(s) selected</span>
</div>

<DataTable TItem="BookingDto" Items="_filteredJobs" Loading="_loading" ShowSearch="false">
    <HeaderTemplate>
        <th style="width:40px;">
            <input type="checkbox" @onchange="ToggleAll" />
        </th>
        <th>ID</th>
        <th>Driver</th>
        <th>Scope</th>
        <th>Pickup</th>
        <th>Date</th>
        <th>Price</th>
    </HeaderTemplate>
    <RowTemplate Context="b">
        <td><input type="checkbox" checked="@_selectedJobs.Contains(b.Id)" @onchange="() => ToggleJob(b.Id)" /></td>
        <td>@b.Id</td>
        <td>@(b.DriverName ?? "-")</td>
        <td>@GetScopeLabel(b.Scope)</td>
        <td>@b.PickupAddress</td>
        <td>@b.PickupDateTime.ToString("dd/MM/yyyy")</td>
        <td>&pound;@b.Price.ToString("N2")</td>
    </RowTemplate>
</DataTable>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="form-success">@_message</div>
}

@code {
    private List<BookingDto> _jobs = new();
    private List<DriverDto> _drivers = new();
    private HashSet<int> _selectedJobs = new();
    private bool _loading = true;
    private bool _processing;
    private string? _message;
    private int _selectedDriverId;
    private int _selectedScope = -1;

    private IEnumerable<BookingDto> _filteredJobs => _jobs
        .Where(j => _selectedDriverId == 0 || j.UserId == _selectedDriverId)
        .Where(j => _selectedScope == -1 || j.Scope == _selectedScope);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _drivers = await Api.GetDriversAsync();
            _jobs = await Api.GetUninvoicedDriverJobsAsync();
        }
        catch { }
        finally { _loading = false; }
    }

    private void ApplyFilters()
    {
        _selectedJobs.Clear();
        StateHasChanged();
    }

    private void ToggleJob(int id)
    {
        if (!_selectedJobs.Remove(id)) _selectedJobs.Add(id);
    }

    private void ToggleAll(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false))
            _selectedJobs = _filteredJobs.Select(j => j.Id).ToHashSet();
        else
            _selectedJobs.Clear();
    }

    private async Task CreateStatement()
    {
        _processing = true;
        _message = null;
        try
        {
            await Api.PostStatementAsync(new { BookingIds = _selectedJobs.ToList() });
            _message = $"Statement created for {_selectedJobs.Count} jobs.";
            _selectedJobs.Clear();
            _jobs = await Api.GetUninvoicedDriverJobsAsync();
        }
        catch { _message = "Failed to create statement."; }
        finally { _processing = false; }
    }

    private static string GetScopeLabel(int? scope) => scope switch
    {
        0 => "Cash",
        1 => "Account",
        2 => "Card",
        _ => "-"
    };
}

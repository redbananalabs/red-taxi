@page "/admin/billing/credit-journeys"
@attribute [Authorize]
@inject AdminApiClient Api

<PageTitle>Credit Journeys - Red Taxi Admin</PageTitle>

<div class="page-header">
    <h1>Credit Journeys</h1>
    <p class="text-secondary">View and manage credit journey adjustments.</p>
</div>

<FormCard Title="Filters">
    <div class="form-row">
        <div class="form-group">
            <label>From</label>
            <InputDate class="form-input" @bind-Value="_dateFrom" />
        </div>
        <div class="form-group">
            <label>To</label>
            <InputDate class="form-input" @bind-Value="_dateTo" />
        </div>
        <div class="form-group" style="align-self:flex-end;">
            <button class="btn btn-primary" @onclick="() => _loaded = true">Search</button>
        </div>
    </div>
</FormCard>

@if (_loaded)
{
    <FormCard Title="Credit Journeys">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Account</th>
                    <th>Original Price</th>
                    <th>Credit Amount</th>
                    <th>Reason</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <tr><td colspan="6" style="text-align:center;color:#999;">No credit journeys found - connect to API</td></tr>
            </tbody>
        </table>
    </FormCard>
}

@code {
    private DateTime _dateFrom = DateTime.Today.AddMonths(-1);
    private DateTime _dateTo = DateTime.Today;
    private bool _loaded;
}

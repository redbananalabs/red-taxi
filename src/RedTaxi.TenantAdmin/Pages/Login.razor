@page "/login"
@layout AdminLayout
@inject AdminApiClient Api
@inject AuthStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Login - Red Taxi Admin</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h2 class="brand-text">Red<span class="brand-accent">Taxi</span> Admin</h2>
        <EditForm Model="@_model" OnValidSubmit="HandleLogin">
            <div class="form-group">
                <label>Email</label>
                <InputText class="form-input" @bind-Value="_model.Email" placeholder="admin@company.com" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <InputText class="form-input" type="password" @bind-Value="_model.Password" />
            </div>
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="form-error">@_error</div>
            }
            <button type="submit" class="btn btn-primary btn-block" disabled="@_loading">
                @if (_loading) { <span class="spinner-sm"></span> } else { <span>Sign In</span> }
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;
        try
        {
            var result = await Api.LoginAsync(new LoginRequest(_model.Email, _model.Password, "ace"));
            if (result is not null)
            {
                await AuthState.MarkUserAsAuthenticated(result.AccessToken);
                Nav.NavigateTo("admin");
            }
            else
            {
                _error = "Invalid email or password.";
            }
        }
        catch
        {
            _error = "Login failed. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}

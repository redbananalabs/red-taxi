@page "/admin/availability"
@attribute [Authorize]
@inject AdminApiClient Api

<PageTitle>Availability - Red Taxi Admin</PageTitle>

<div class="page-header">
    <h1>Driver Availability</h1>
</div>

<FormCard Title="Date Selection">
    <div class="form-row">
        <div class="form-group">
            <label>Date</label>
            <InputDate class="form-input" @bind-Value="_selectedDate" />
        </div>
        <div class="form-group" style="align-self:flex-end;">
            <button class="btn btn-primary" @onclick="LoadAvailability">Load</button>
        </div>
    </div>
</FormCard>

@if (_loading)
{
    <div class="table-loading"><div class="spinner"></div><span>Loading...</span></div>
}
else
{
    <DataTable TItem="DriverAvailabilityDto" Items="_availability" Loading="false" ShowSearch="false">
        <HeaderTemplate>
            <th>Driver ID</th>
            <th>Start</th>
            <th>End</th>
            <th>Type</th>
            <th>Details</th>
            <th>Flexible</th>
        </HeaderTemplate>
        <RowTemplate Context="a">
            <td>@a.UserId</td>
            <td>@a.StartTime.ToString(@"hh\:mm")</td>
            <td>@a.EndTime.ToString(@"hh\:mm")</td>
            <td>@GetAvailabilityType(a.AvailabilityType)</td>
            <td>@(a.Details ?? "-")</td>
            <td>@(a.GiveOrTake ? "Yes" : "No")</td>
        </RowTemplate>
    </DataTable>
}

@code {
    private DateTime _selectedDate = DateTime.Today;
    private List<DriverAvailabilityDto> _availability = new();
    private bool _loading;

    protected override async Task OnInitializedAsync() => await LoadAvailability();

    private async Task LoadAvailability()
    {
        _loading = true;
        try { _availability = await Api.GetAvailabilityAsync(_selectedDate); }
        catch { }
        finally { _loading = false; }
    }

    private static string GetAvailabilityType(int type) => type switch
    {
        0 => "Available",
        1 => "Unavailable",
        2 => "Holiday",
        _ => "Unknown"
    };
}

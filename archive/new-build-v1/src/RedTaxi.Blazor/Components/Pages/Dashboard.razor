@page "/"
@inject DispatchState State
@inject ApiService Api
@inject SignalRService SignalR
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Dispatch Console - Red Taxi</PageTitle>

<div class="dispatch-split" id="dispatch-split">
    <!-- LEFT PANEL: Booking Form (always visible) -->
    <div class="split-left" id="split-left">
        <BookingForm OnClose="HandleFormClear"
                     OnBookingCreated="HandleBookingCreated"
                     AlwaysVisible="true" />
    </div>

    <!-- SPLITTER HANDLE -->
    <div class="split-handle" id="split-handle">
        <div class="split-handle-grip"></div>
    </div>

    <!-- RIGHT PANEL: Tabs (Scheduler / Map) -->
    <div class="split-right" id="split-right">
        <!-- Tab bar -->
        <div class="tab-bar">
            <div class="tab-bar-left">
                <button class="tab-btn @(_activeTab == Tab.Scheduler ? "tab-active" : "")"
                        @onclick="() => SetTab(Tab.Scheduler)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="tab-icon">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    Scheduler
                </button>
                <button class="tab-btn @(_activeTab == Tab.Map ? "tab-active" : "")"
                        @onclick="() => SetTab(Tab.Map)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="tab-icon">
                        <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                        <line x1="8" y1="2" x2="8" y2="18" />
                        <line x1="16" y1="6" x2="16" y2="22" />
                    </svg>
                    Map
                </button>
            </div>
            <div class="tab-bar-right">
                <span class="tab-kpi" title="Today's bookings">
                    <span class="tab-kpi-val font-mono">@_kpis.TodayBookings</span> today
                </span>
                <span class="tab-kpi tab-kpi-warn" title="Unallocated">
                    <span class="tab-kpi-val font-mono">@_kpis.UnallocatedBookings</span> unalloc
                </span>
                <span class="tab-kpi tab-kpi-ok" title="Completed">
                    <span class="tab-kpi-val font-mono">@_kpis.CompletedToday</span> done
                </span>
            </div>
        </div>

        <!-- Tab content -->
        <div class="tab-content">
            @if (_activeTab == Tab.Scheduler)
            {
                <Timeline FullHeight="true" />
            }
            else
            {
                <MapView />
            }
        </div>

        <!-- Context panel (right slide) -->
        <div class="panel-right @(State.IsBookingDetailOpen || State.IsDriverDetailOpen ? "panel-open" : "")">
            @if (State.IsBookingDetailOpen && State.SelectedBooking != null)
            {
                <BookingDetailPanel Booking="State.SelectedBooking"
                                    OnClose="() => State.CloseBookingDetail()"
                                    OnAllocate="HandleAllocateRequest" />
            }
            else if (State.IsDriverDetailOpen && State.SelectedDriver != null)
            {
                <DriverDetailPanel Driver="State.SelectedDriver"
                                   OnClose="() => State.CloseDriverDetail()" />
            }
        </div>

        <!-- Driver selector modal -->
        @if (State.IsDriverSelectorOpen && State.SelectedBooking != null)
        {
            <DriverSelector BookingId="State.SelectedBooking.Id"
                            OnClose="() => State.CloseDriverSelector()"
                            OnDriverSelected="HandleDriverAllocated" />
        }
    </div>
</div>

@code {
    private enum Tab { Scheduler, Map }

    private Tab _activeTab = Tab.Scheduler;
    private DashboardKpiDto _kpis = new(0, 0, 0, 0m, 0, 0);

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
        SignalR.OnStateUpdated += HandleSignalRUpdate;
        SignalR.OnConnectionChanged += StateHasChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await SignalR.StartAsync();
        await LoadKpis();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("splitterInterop.init"); }
            catch { }
        }
    }

    private async Task LoadKpis()
    {
        try { _kpis = await Api.GetDashboardKpisAsync() ?? _kpis; }
        catch { }
    }

    private void SetTab(Tab tab)
    {
        _activeTab = tab;
        StateHasChanged();
    }

    private void HandleFormClear()
    {
        // No-op — form stays visible in always-visible mode, just resets internally
    }

    private async Task HandleBookingCreated(BookingDto booking)
    {
        State.SelectBooking(booking);
        await LoadKpis();
        StateHasChanged();
    }

    private void HandleAllocateRequest() => State.OpenDriverSelector();

    private async Task HandleDriverAllocated(int driverUserId)
    {
        if (State.SelectedBooking != null)
        {
            try
            {
                await Api.AllocateDriverAsync(State.SelectedBooking.Id, driverUserId);
                State.CloseDriverSelector();
                await LoadKpis();
            }
            catch { }
        }
    }

    private async void HandleSignalRUpdate()
    {
        await InvokeAsync(async () =>
        {
            await LoadKpis();
            StateHasChanged();
        });
    }

    public ValueTask DisposeAsync()
    {
        State.OnChange -= StateHasChanged;
        SignalR.OnStateUpdated -= HandleSignalRUpdate;
        SignalR.OnConnectionChanged -= StateHasChanged;
        return ValueTask.CompletedTask;
    }
}

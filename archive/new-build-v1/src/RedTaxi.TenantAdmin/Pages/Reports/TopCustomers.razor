@page "/admin/reports/top-customers"
@attribute [Authorize]

<PageTitle>Top Customers - Red Taxi Admin</PageTitle>

<div class="page-header">
    <h1>Top Customers</h1>
</div>

<FormCard Title="Period">
    <div class="form-row">
        <div class="form-group">
            <label>From</label>
            <InputDate class="form-input" @bind-Value="_dateFrom" />
        </div>
        <div class="form-group">
            <label>To</label>
            <InputDate class="form-input" @bind-Value="_dateTo" />
        </div>
        <div class="form-group" style="align-self:flex-end;">
            <button class="btn btn-primary" @onclick="() => _generated = true">Generate</button>
        </div>
    </div>
</FormCard>

@if (_generated)
{
    <FormCard Title="Top Customers">
        <div class="table-empty">Top customer data will appear here when connected to the reporting API.</div>
    </FormCard>
}

@code {
    private DateTime _dateFrom = DateTime.Today.AddMonths(-1);
    private DateTime _dateTo = DateTime.Today;
    private bool _generated;
}

@page "/admin/reports/revenue"
@attribute [Authorize]

<PageTitle>Revenue Report - Red Taxi Admin</PageTitle>

<div class="page-header">
    <h1>Revenue Report</h1>
</div>

<FormCard Title="Period">
    <div class="form-row">
        <div class="form-group">
            <label>From</label>
            <InputDate class="form-input" @bind-Value="_dateFrom" />
        </div>
        <div class="form-group">
            <label>To</label>
            <InputDate class="form-input" @bind-Value="_dateTo" />
        </div>
        <div class="form-group" style="align-self:flex-end;">
            <button class="btn btn-primary" @onclick="() => _generated = true">Generate</button>
        </div>
    </div>
</FormCard>

@if (_generated)
{
    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-value">&pound;0.00</div><div class="kpi-label">Total Revenue</div></div>
        <div class="kpi-card"><div class="kpi-value">&pound;0.00</div><div class="kpi-label">Cash</div></div>
        <div class="kpi-card"><div class="kpi-value">&pound;0.00</div><div class="kpi-label">Card</div></div>
        <div class="kpi-card"><div class="kpi-value">&pound;0.00</div><div class="kpi-label">Account</div></div>
    </div>
    <FormCard Title="Revenue Chart">
        <div class="chart-placeholder">Revenue chart placeholder - connect to reporting API</div>
    </FormCard>
}

@code {
    private DateTime _dateFrom = DateTime.Today.AddMonths(-1);
    private DateTime _dateTo = DateTime.Today;
    private bool _generated;
}
